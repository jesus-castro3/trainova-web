# Copy to .env and fill in your values
PORT=3000

# App Store URL once live (e.g. https://apps.apple.com/mx/app/trainova/id123456789)
APP_STORE_URL=https://apps.apple.com/mx/app/trainova/id

# Apple App ID (numeric, from App Store Connect)
APP_ID=

# Apple Team ID (from developer.apple.com)
TEAM_ID=

# App bundle identifier
BUNDLE_ID=com.trainova.Trainova

# Custom URL scheme used in the iOS app
APP_SCHEME=trainova
