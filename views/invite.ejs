<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t.invite.title %></title>
  <meta name="description" content="<%= t.invite.sub %>" />
  <% if (appId) { %>
  <meta name="apple-itunes-app" content="app-id=<%= appId %>, app-argument=<%= deepLink %>">
  <% } %>
  <%- include('partials/head') %>
</head>
<body>

  <div class="invite-page">
    <a href="/" style="margin-bottom:32px;display:inline-flex;align-items:center;gap:8px;" aria-label="Trainova home">
      <img src="/assets/logo-mark.svg" alt="" width="36" height="36" />
      <span style="font-size:1.125rem;font-weight:800;letter-spacing:-0.03em;background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Trainova</span>
    </a>

    <div class="invite-card">
      <div class="invite-avatar">🏋️</div>
      <h1><%= t.invite.headline %></h1>
      <p><%= t.invite.sub %></p>

      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-text">
            <strong><%= t.invite.step1Title %></strong>
            <span><%= t.invite.step1Sub %></span>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-text">
            <strong><%= t.invite.step2Title %></strong>
            <span><%= t.invite.step2Sub %></span>
          </div>
        </div>
      </div>

      <a href="<%= appStoreUrl %>" class="btn-primary" style="width:100%;justify-content:center;margin-bottom:var(--space-md);">
        <%- appleIcon() %>
        <%= t.invite.primaryBtn %>
      </a>

      <div class="invite-divider"><%= t.invite.divider %></div>

      <a href="<%= deepLink %>" class="btn-ghost" style="width:100%;justify-content:center;">
        <%= t.invite.secondaryBtn %>
      </a>
    </div>

    <p style="margin-top:var(--space-lg);font-size:0.8125rem;color:var(--text-secondary);">
      <%= t.invite.help %> <a href="mailto:hola@trainova.fit" style="color:var(--accent-purple);">hola@trainova.fit</a>
    </p>
  </div>

  <script>
    const isIOS = /iPhone|iPad|iPod/.test(navigator.userAgent)
    if (isIOS) {
      const iframe = document.createElement('iframe')
      iframe.style.display = 'none'
      iframe.src = '<%= deepLink %>'
      document.body.appendChild(iframe)
      setTimeout(() => {
        if (document.hidden || document.webkitHidden) return
        window.location.href = '<%= appStoreUrl %>'
      }, 2500)
    }
  </script>
</body>
</html>
