<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trainova — <%= t.hero.headline1 %> <%= t.hero.headline2 %></title>
  <meta name="description" content="<%= t.hero.sub %>" />
  <meta property="og:title" content="Trainova" />
  <meta property="og:description" content="<%= t.hero.sub %>" />
  <meta property="og:type" content="website" />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

    .orb { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; animation:float 8s ease-in-out infinite; }
    .orb-1 { width:500px; height:500px; background:radial-gradient(circle, rgba(108,99,255,0.18), transparent 70%); top:-150px; left:-100px; animation-delay:0s; }
    .orb-2 { width:400px; height:400px; background:radial-gradient(circle, rgba(78,205,196,0.15), transparent 70%); top:0; right:-80px; animation-delay:-3s; }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-24px)} }

    .hero-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-2xl); align-items:center; }
    @media(max-width:780px){ .hero-grid{grid-template-columns:1fr;text-align:center} .hero-grid .hero-actions{justify-content:center} .phone-wrap{display:flex;justify-content:center} }

    .phone { width:220px; height:440px; background:var(--surface); border-radius:36px; border:2px solid var(--border); position:relative; overflow:hidden; box-shadow:0 40px 80px rgba(0,0,0,0.6),0 0 0 1px rgba(255,255,255,0.05); }
    .phone::before { content:''; position:absolute; top:14px; left:50%; transform:translateX(-50%); width:60px; height:8px; background:var(--border); border-radius:4px; z-index:10; }
    .phone-screen { position:absolute; inset:28px 0 0; padding:16px 14px 14px; display:flex; flex-direction:column; gap:10px; }
    .phone-header { font-size:11px; font-weight:700; color:var(--text-secondary); letter-spacing:0.06em; text-transform:uppercase; }
    .phone-title { font-size:15px; font-weight:800; color:var(--text-primary); }
    .phone-card { background:var(--surface-raised); border-radius:12px; padding:12px; border:1px solid var(--border); }
    .phone-card-label { font-size:9px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-secondary); margin-bottom:4px; }
    .phone-card-value { font-size:13px; font-weight:700; color:var(--text-primary); }
    .phone-exercise-row { display:flex; justify-content:space-between; align-items:center; padding:8px 10px; background:var(--surface-raised); border-radius:8px; border:1px solid var(--border); }
    .phone-exercise-name { font-size:11px; font-weight:600; color:var(--text-primary); }
    .phone-exercise-sets { font-size:10px; color:var(--text-secondary); }
    .phone-pill { display:inline-block; background:rgba(108,99,255,0.2); color:var(--accent-purple); font-size:9px; font-weight:700; padding:2px 8px; border-radius:999px; }
    .phone-btn { background:var(--gradient); border-radius:10px; padding:10px; text-align:center; font-size:11px; font-weight:700; color:#fff; margin-top:auto; }
    .phone-float { position:relative; }
    .phone-float .phone-2 { position:absolute; top:40px; left:150px; width:180px; height:360px; opacity:0.55; transform:rotate(6deg); }

    .how-it-works { padding:var(--space-3xl) 0; border-top:1px solid var(--border); }
    .steps-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-xl); position:relative; }
    .steps-grid::before { content:''; position:absolute; top:28px; left:calc(16.66% + 20px); right:calc(16.66% + 20px); height:1px; background:linear-gradient(to right,transparent,var(--border),transparent); }
    @media(max-width:640px){ .steps-grid{grid-template-columns:1fr} .steps-grid::before{display:none} }
    .step-item { text-align:center; padding:0 var(--space-sm); }
    .step-icon-wrap { width:56px; height:56px; border-radius:50%; background:var(--surface); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-size:1.375rem; margin:0 auto var(--space-md); position:relative; z-index:1; }
    .step-item h3 { font-size:1rem; font-weight:700; margin-bottom:var(--space-xs); }
    .step-item p { font-size:0.875rem; color:var(--text-secondary); line-height:1.6; }

    .showcase { padding:var(--space-3xl) 0; border-top:1px solid var(--border); }
    .showcase-grid { display:grid; grid-template-columns:1fr 1fr; gap:2px; border-radius:var(--radius-xl); overflow:hidden; border:1px solid var(--border); }
    @media(max-width:700px){ .showcase-grid{grid-template-columns:1fr} }
    .showcase-panel { padding:var(--space-2xl) var(--space-xl); background:var(--surface); }
    .showcase-panel:first-child { border-right:1px solid var(--border); }
    @media(max-width:700px){ .showcase-panel:first-child{border-right:none;border-bottom:1px solid var(--border)} }
    .showcase-panel h3 { font-size:1.375rem; font-weight:800; letter-spacing:-0.02em; margin-bottom:var(--space-sm); }
    .showcase-panel > p { color:var(--text-secondary); font-size:0.9375rem; margin-bottom:var(--space-lg); line-height:1.65; }

    .proof-bar { border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:var(--space-xl) 0; }
    .proof-inner { display:flex; align-items:center; justify-content:center; gap:var(--space-3xl); flex-wrap:wrap; }
    .proof-stat { text-align:center; }
    .proof-stat strong { display:block; font-size:2rem; font-weight:900; background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; letter-spacing:-0.03em; }
    .proof-stat span { font-size:0.875rem; color:var(--text-secondary); }

    .testimonials { padding:var(--space-3xl) 0; border-top:1px solid var(--border); }
    .testimonials-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-lg); }
    @media(max-width:700px){ .testimonials-grid{grid-template-columns:1fr} }
    .testimonial-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-xl); padding:var(--space-xl); }
    .testimonial-stars { color:var(--warning); font-size:0.875rem; margin-bottom:var(--space-md); }
    .testimonial-card blockquote { font-size:0.9375rem; color:var(--text-secondary); line-height:1.7; margin-bottom:var(--space-md); font-style:italic; }
    .testimonial-author { font-size:0.875rem; font-weight:600; }
    .testimonial-role { font-size:0.8125rem; color:var(--text-secondary); }

    .sticky-cta { display:none; position:fixed; bottom:0; left:0; right:0; padding:var(--space-md) var(--space-lg); background:rgba(26,26,46,0.95); backdrop-filter:blur(16px); border-top:1px solid var(--border); z-index:200; }
    @media(max-width:640px){ .sticky-cta{display:block} }
    .sticky-cta .btn-primary { width:100%; justify-content:center; }
  </style>
</head>
<body>

  <%- include('partials/nav') %>

  <!-- Hero -->
  <section class="hero" style="padding:80px 0 64px; overflow:visible;">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="container">
      <div class="hero-grid">
        <div>
          <div class="hero-badge" style="margin-bottom:var(--space-lg);">
            <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="5" fill="#4ECDC4" opacity="0.3"/><circle cx="6" cy="6" r="3" fill="#4ECDC4"/></svg>
            <%= t.hero.badge %>
          </div>
          <h1 style="text-align:left;font-size:clamp(2.25rem,5.5vw,3.75rem);">
            <%= t.hero.headline1 %><br/>
            <span class="gradient-text"><%= t.hero.headline2 %></span>
          </h1>
          <p style="text-align:left;margin:var(--space-lg) 0 var(--space-xl);font-size:1.0625rem;">
            <%= t.hero.sub %>
          </p>
          <div class="hero-actions" style="justify-content:flex-start;">
            <a href="<%= appStoreUrl %>" class="appstore-badge">
              <%- appleIcon() %>
              <%= t.hero.cta %>
            </a>
            <span style="font-size:0.8125rem;color:var(--text-secondary);"><%= t.hero.ctaSub %></span>
          </div>
        </div>

        <!-- Phone mockups -->
        <div class="phone-wrap">
          <div class="phone-float">
            <div class="phone phone-2">
              <div class="phone-screen">
                <div class="phone-header"><%= t.phone.dashboard %></div>
                <div class="phone-title"><%= t.phone.clients %></div>
                <div class="phone-card">
                  <div class="phone-card-label"><%= t.phone.thisWeek %></div>
                  <div style="display:flex;gap:6px;margin-top:6px;">
                    <div style="flex:1;background:rgba(108,99,255,0.3);border-radius:6px;height:36px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--accent-purple);">4/5</div>
                    <div style="flex:1;background:rgba(78,205,196,0.15);border-radius:6px;height:36px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--accent-teal);">87%</div>
                    <div style="flex:1;background:rgba(0,230,118,0.1);border-radius:6px;height:36px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--success);">↑12%</div>
                  </div>
                </div>
                <div class="phone-exercise-row"><span class="phone-exercise-name"><%= t.phone.client1 %></span><span class="phone-pill"><%= t.phone.done %></span></div>
                <div class="phone-exercise-row"><span class="phone-exercise-name"><%= t.phone.client2 %></span><span style="font-size:9px;color:var(--warning);"><%= t.phone.pending %></span></div>
                <div class="phone-exercise-row"><span class="phone-exercise-name"><%= t.phone.client3 %></span><span class="phone-pill"><%= t.phone.done %></span></div>
              </div>
            </div>
            <div class="phone">
              <div class="phone-screen">
                <div class="phone-header"><%= t.phone.today %></div>
                <div class="phone-title"><%= t.phone.startWorkout %></div>
                <div class="phone-card">
                  <div class="phone-card-label"><%= t.phone.workoutLabel %></div>
                  <div class="phone-card-value"><%= t.phone.workoutMeta %></div>
                </div>
                <div class="phone-exercise-row">
                  <div><div class="phone-exercise-name"><%= t.phone.ex1 %></div><div class="phone-exercise-sets"><%= t.phone.ex1Sets %></div></div>
                  <span style="color:var(--success);font-size:14px;">✓</span>
                </div>
                <div class="phone-exercise-row">
                  <div><div class="phone-exercise-name"><%= t.phone.ex2 %></div><div class="phone-exercise-sets"><%= t.phone.ex2Sets %></div></div>
                  <span style="color:var(--success);font-size:14px;">✓</span>
                </div>
                <div class="phone-exercise-row" style="border-color:var(--accent-purple);background:rgba(108,99,255,0.08);">
                  <div><div class="phone-exercise-name"><%= t.phone.ex3 %></div><div class="phone-exercise-sets"><%= t.phone.ex3Sets %></div></div>
                  <span style="color:var(--accent-purple);font-size:14px;">▶</span>
                </div>
                <div class="phone-btn"><%= t.phone.logSet %></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof bar -->
  <div class="proof-bar">
    <div class="container">
      <div class="proof-inner">
        <div class="proof-stat"><strong><%= t.proof.stat1Value %></strong><span><%= t.proof.stat1Label %></span></div>
        <div class="proof-stat"><strong><%= t.proof.stat2Value %></strong><span><%= t.proof.stat2Label %></span></div>
        <div class="proof-stat"><strong><%= t.proof.stat3Value %></strong><span><%= t.proof.stat3Label %></span></div>
        <div class="proof-stat"><strong><%= t.proof.stat4Value %></strong><span><%= t.proof.stat4Label %></span></div>
      </div>
    </div>
  </div>

  <!-- How it works -->
  <section class="how-it-works">
    <div class="container">
      <p class="section-label"><%= t.how.sectionLabel %></p>
      <h2 class="section-title"><%= t.how.title %></h2>
      <div class="steps-grid">
        <div class="step-item">
          <div class="step-icon-wrap" style="background:rgba(108,99,255,0.1);border-color:rgba(108,99,255,0.3);"><%= t.how.step1Icon %></div>
          <h3><%= t.how.step1Title %></h3>
          <p><%= t.how.step1Body %></p>
        </div>
        <div class="step-item">
          <div class="step-icon-wrap" style="background:rgba(78,205,196,0.1);border-color:rgba(78,205,196,0.3);"><%= t.how.step2Icon %></div>
          <h3><%= t.how.step2Title %></h3>
          <p><%= t.how.step2Body %></p>
        </div>
        <div class="step-item">
          <div class="step-icon-wrap" style="background:rgba(0,230,118,0.1);border-color:rgba(0,230,118,0.3);"><%= t.how.step3Icon %></div>
          <h3><%= t.how.step3Title %></h3>
          <p><%= t.how.step3Body %></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Showcase -->
  <section class="showcase">
    <div class="container">
      <p class="section-label"><%= t.showcase.sectionLabel %></p>
      <h2 class="section-title" style="margin-bottom:var(--space-xl);"><%= t.showcase.title %></h2>
      <div class="showcase-grid">
        <div class="showcase-panel">
          <span class="role-pill trainer"><%= t.showcase.trainerPill %></span>
          <h3><%= t.showcase.trainerTitle %></h3>
          <p><%= t.showcase.trainerSub %></p>
          <ul class="role-list">
            <% t.showcase.trainerFeatures.forEach(f => { %><li><%= f %></li><% }) %>
          </ul>
        </div>
        <div class="showcase-panel">
          <span class="role-pill client"><%= t.showcase.clientPill %></span>
          <h3><%= t.showcase.clientTitle %></h3>
          <p><%= t.showcase.clientSub %></p>
          <ul class="role-list">
            <% t.showcase.clientFeatures.forEach(f => { %><li><%= f %></li><% }) %>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials">
    <div class="container">
      <p class="section-label"><%= t.testimonials.sectionLabel %></p>
      <h2 class="section-title"><%= t.testimonials.title %></h2>
      <div class="testimonials-grid">
        <% t.testimonials.items.forEach(item => { %>
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <blockquote>"<%= item.quote %>"</blockquote>
          <div class="testimonial-author"><%= item.name %></div>
          <div class="testimonial-role"><%= item.role %></div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <div class="hero-badge" style="display:inline-flex;margin-bottom:var(--space-lg);">
          <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="5" fill="#4ECDC4" opacity="0.3"/><circle cx="6" cy="6" r="3" fill="#4ECDC4"/></svg>
          <%= t.cta.badge %>
        </div>
        <h2><%= t.cta.headline1 %> <span class="gradient-text"><%= t.cta.headlineGradient %></span> <%= t.cta.headline2 %></h2>
        <p><%= t.cta.sub %></p>
        <a href="<%= appStoreUrl %>" class="appstore-badge" style="display:inline-flex;">
          <%- appleIcon() %>
          <%= t.cta.btn %>
        </a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <!-- Sticky mobile CTA -->
  <div class="sticky-cta">
    <a href="<%= appStoreUrl %>" class="btn-primary">
      <%- appleIcon() %>
      <%= t.cta.stickyBtn %>
    </a>
  </div>

</body>
</html>
