<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t.privacy.title %> — Trainova</title>
  <%- include('partials/head') %>
</head>
<body>

  <%- include('partials/nav') %>

  <main class="privacy-page">
    <h1><%= t.privacy.title %></h1>
    <p class="updated"><%= t.privacy.updated %></p>
    <p><%= t.privacy.intro %></p>

    <h2><%= t.privacy.s1Title %></h2>
    <p><%= t.privacy.s1Intro %></p>
    <ul><% t.privacy.s1Items.forEach(i => { %><li><%= i %></li><% }) %></ul>

    <h2><%= t.privacy.s2Title %></h2>
    <ul><% t.privacy.s2Items.forEach(i => { %><li><%= i %></li><% }) %></ul>
    <p><%= t.privacy.s2Footer %></p>

    <h2><%= t.privacy.s3Title %></h2>
    <p><%= t.privacy.s3Body %></p>

    <h2><%= t.privacy.s4Title %></h2>
    <p><%= t.privacy.s4Body1 %></p>
    <p><%= t.privacy.s4Body2 %></p>

    <h2><%= t.privacy.s5Title %></h2>
    <ul><% t.privacy.s5Items.forEach(i => { %><li><%- i %></li><% }) %></ul>

    <h2><%= t.privacy.s6Title %></h2>
    <p><%= t.privacy.s6Body %></p>

    <h2><%= t.privacy.s7Title %></h2>
    <p><%= t.privacy.s7Body %></p>

    <h2><%= t.privacy.s8Title %></h2>
    <p><%= t.privacy.s8Body %> <a href="mailto:hola@trainova.fit" style="color:var(--accent-purple);">hola@trainova.fit</a></p>
  </main>

  <%- include('partials/footer') %>

</body>
</html>
